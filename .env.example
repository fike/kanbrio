# Kanbrio Environment Configuration
# Copy to .env and adjust values as needed.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=kanbrio

# RUST_LOG — controls API log level (trace, debug, info, warn, error)
RUST_LOG=info

# OpenTelemetry (auto-configured via docker-compose networks)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# API
API_PORT=3000

# Web (Vite dev server)
WEB_PORT=5173
