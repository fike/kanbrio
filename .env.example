# Kanbrio Environment Configuration
# Copy to `.env` and adjust values for your environment.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_DEV_ONLY
POSTGRES_DB=kanbrio
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Database URL (used by API and SQLx)
DATABASE_URL=postgres://postgres:CHANGE_ME_DEV_ONLY@localhost:5432/kanbrio

# API
API_PORT=3000
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=kanbrio-api

# Web
WEB_PORT=5173

# Observability
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_DEV_ONLY
